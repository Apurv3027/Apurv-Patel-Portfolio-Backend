# Server
NODE_ENV=development
PORT=5000

# Database
MONGO_URI=mongodb://localhost:27017/portfolio_analytics

# Frontend URLs (used for CORS and Socket.IO)
CLIENT_URL=https://your-frontend-domain.vercel.app
LOCAL_CLIENT_URL=http://localhost:3000

# Optional: comma-separated list overrides CLIENT_URL + LOCAL_CLIENT_URL
# CORS_ORIGINS=http://localhost:3000,https://your-frontend-domain.vercel.app
